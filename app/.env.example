# ═══════════════════════════════════════════════════════════════════════
# LicenseRadar — Environment Configuration
# Copy this file to .env and fill in your values.
# ═══════════════════════════════════════════════════════════════════════

# ── Database ──────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=licenseradar
DB_USER=root
DB_PASS=

# ── Azure / Microsoft Graph API ──────────────────────────────────────
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# ── SMTP (for Email OTP) ─────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM_NAME=LicenseRadar
SMTP_FROM_EMAIL=

# ── Application ──────────────────────────────────────────────────────
APP_NAME=LicenseRadar
APP_URL=https://licenseradar.yourdomain.com
APP_DEBUG=false

# ── Security ─────────────────────────────────────────────────────────
SESSION_LIFETIME=1800
SESSION_ABSOLUTE=28800
RATE_LIMIT_ATTEMPTS=5
RATE_LIMIT_WINDOW=900
