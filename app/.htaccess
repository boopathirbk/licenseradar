# ═══════════════════════════════════════════════════════════════════════
# LicenseRadar — App Root .htaccess
# Deny all web access to app root (only public/ should be accessible)
# ═══════════════════════════════════════════════════════════════════════

<IfModule mod_authz_core.c>
    Require all denied
</IfModule>

<IfModule !mod_authz_core.c>
    Order deny,allow
    Deny from all
</IfModule>
